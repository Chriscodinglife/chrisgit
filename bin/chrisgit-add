#!/usr/bin/env ruby

require "digest"
require "zlib"
require "fileutils"

CHRISGIT_DIRECTORY = ".chrisgit".freeze
OBJECTS_DIRECTORY = "#{CHRISGIT_DIRECTORY}/objects".freeze
INDEX_PATH = "#{CHRISGIT_DIRECTORY}/index"

unless Dir.exist? CHRISGIT_DIRECTORY
  $stderr.puts "Not a Chrisgit project"
  exit 1
end

path = ARGV.first

if path.nil?
  $stderr.puts "No path specified"
  exit 1
end

file_contents = File.read(path)
sha = Digest::SHA1.hexdigest file_contents
blob = Zlib::Deflate.deflate(file_contents)

# Split the sha by getting the first two letters
# And the rest in separate parts
sha_part1 = sha.slice(0..1)
sha_part2 = sha.slice(2..-1)

object_directory = "#{OBJECTS_DIRECTORY}/#{sha_part1}"
FileUtils.mkdir_p object_directory
blob_path = "#{object_directory}/#{sha_part2}"

# Write the blob contents into the blob_path
File.open(blob_path, 'w') do |file|
  file.print(blob)
end

# Write the index out
File.open(INDEX_PATH, 'a') do |file|
  file.puts "#{sha} #{path}"
end
