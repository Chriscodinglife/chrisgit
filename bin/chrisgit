#!/usr/bin/env ruby

# bin/chrisgit

command, *args = ARGV

if command.nil?
  warn 'Usage: chrisgit <command> [<args>]'
  exit 1
end

path_to_command = File.expand_path("../chrisgit-#{command}", __FILE__)

unless File.exist? path_to_command
  warn 'No such command'
  exit 1
end

exec path_to_command, *args
